{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "SmartSwing Dev Server (port 8000)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8000
    },
    {
      "name": "Vercel Dev (port 3000)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vercel", "dev", "--listen", "3000"],
      "port": 3000
    }
  ]
}
