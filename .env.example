# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_here

# Stripe Billing Configuration
PUBLIC_APP_URL=https://www.smartswingai.com
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER_MONTHLY=price_your_player_plan
STRIPE_PRICE_PRO_MONTHLY=price_your_performance_plan
STRIPE_PRICE_ELITE_MONTHLY=price_your_tournament_plan

# Stripe Yearly Price IDs (required for annual billing toggle on checkout)
# These already exist in Stripe — copy the price IDs from your Stripe dashboard
# or use the values below if you used the SmartSwing setup script
STRIPE_PRICE_STARTER_YEARLY=price_1TFk1vF46UFnxYd96r5HIlDO
STRIPE_PRICE_PRO_YEARLY=price_1TFk1yF46UFnxYd9L5tEY6C2
STRIPE_PRICE_ELITE_YEARLY=price_1TFk22F46UFnxYd92k3NIXIU

# Stripe Coupon Codes
# Create in Stripe Dashboard → Products → Coupons/Promotion codes, then paste the promotion code ID here
# SWINGAI promo: 100% off first month on the Performance (pro) plan
STRIPE_PROMO_CODE_SWINGAI=promo_your_swingai_promo_code_id

# ── Transactional Email (Resend) ──────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/day, 100/month
# 1. Create API key in Resend Dashboard
# 2. Add and verify the SUBDOMAIN mail.smartswingai.com under Resend → Domains
#    (Use the subdomain — the root domain smartswingai.com may already be claimed
#     globally by another Resend account, which would block verification)
# 3. Set RESEND_FROM_ADDRESS to an address on that verified subdomain
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS=SmartSwing AI <noreply@mail.smartswingai.com>

# Resend Audience ID — create under Resend → Audiences, then paste the ID here
# Used to sync new signups as contacts (enables Broadcasts / bulk campaigns)
RESEND_AUDIENCE_ID=your_resend_audience_id_here

# Resend Webhook Signing Secret — from Resend → Webhooks → Add endpoint
# URL to register: https://www.smartswingai.com/api/resend-webhook
# Events to subscribe: email.bounced, email.complained
# Paste the signing secret (starts with whsec_) here
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret_here

# ── Cron Job Protection ───────────────────────────────────────────────────────
# Random secret to protect /api/cron-win-back from unauthorised calls.
# Vercel sets this automatically if you add it here. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_random_cron_secret_here

# ── Analytics (PostHog) ───────────────────────────────────────────────────────
# Sign up at https://posthog.com (generous free tier: 1M events/month)
# 1. Create a project → copy the Project API Key (starts with phc_)
# 2. Set POSTHOG_KEY in Vercel env vars
# The app will auto-init PostHog and only track users who accept analytics cookies
POSTHOG_KEY=phc_your_posthog_project_api_key

# Optional error tracking
# SENTRY_DSN=your_sentry_dsn
