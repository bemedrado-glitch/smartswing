-- ============================================================================
-- VIEWS (for analytics)
-- ============================================================================

CREATE OR REPLACE VIEW player_stats AS
SELECT 
  p.id,
  p.email,
  p.full_name,
  p.age_range,
  p.gender,
  p.usta_level,
  p.utr_rating,
  p.preferred_hand,
  p.subscription_tier,
  COUNT(a.id) as total_assessments,
  AVG(a.overall_score) as avg_score,
  MAX(a.overall_score) as best_score,
  MIN(a.overall_score) as lowest_score,
  COUNT(CASE WHEN a.analyzed_with_gpt THEN 1 END) as gpt_analyses_count,
  SUM(a.gpt_cost) as total_gpt_cost
FROM profiles p
LEFT JOIN assessments a ON p.id = a.user_id
GROUP BY p.id;

