{
  "version": 2,
  "redirects": [
    {
      "source": "/competitor-analysis.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/gpt-ui-components.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/index-analyzer.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/index-integrated.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/integration-settings.html",
      "destination": "/settings.html",
      "permanent": false
    },
    {
      "source": "/review.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/review-all.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/smartswing-ultimate.html",
      "destination": "/",
      "permanent": false
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(), payment=(self), fullscreen=(self)"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://smartswingai.com https://www.smartswingai.com"
        }
      ]
    },
    {
      "source": "/(analyze|dashboard|coach-dashboard|cart|checkout|login|signup|settings)\\.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
