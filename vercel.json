{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron-win-back",
      "schedule": "0 10 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/contact-8",
      "destination": "/contact.html",
      "permanent": true
    },
    {
      "source": "/quiz-pickleball-1",
      "destination": "/pickleball.html",
      "permanent": true
    },
    {
      "source": "/refer-friends",
      "destination": "/refer-friends.html",
      "permanent": true
    },
    {
      "source": "/blank",
      "destination": "/privacy-policy.html",
      "permanent": true
    },
    {
      "source": "/blank-1",
      "destination": "/accessibility.html",
      "permanent": true
    },
    {
      "source": "/blank-2",
      "destination": "/user-agreement.html",
      "permanent": true
    },
    {
      "source": "/blank-3",
      "destination": "/refund-policy.html",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/blog.html",
      "permanent": true
    },
    {
      "source": "/blog/:slug*",
      "destination": "/blog.html",
      "permanent": true
    },
    {
      "source": "/post/:slug*",
      "destination": "/blog.html",
      "permanent": true
    },
    {
      "source": "/pricing-plans/list",
      "destination": "/pricing.html",
      "permanent": true
    },
    {
      "source": "/competitor-analysis.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/gpt-ui-components.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/index-analyzer.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/index-integrated.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/integration-settings.html",
      "destination": "/settings.html",
      "permanent": false
    },
    {
      "source": "/review.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/review-all.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/smartswing-ultimate.html",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/marketing/:_route",
      "destination": "/api/marketing?_route=:_route"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(), payment=(self), fullscreen=(self)"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://smartswingai.com https://www.smartswingai.com; base-uri 'self'; object-src 'none'; form-action 'self' https://checkout.stripe.com https://billing.stripe.com"
        }
      ]
    },
    {
      "source": "/(dashboard|coach-dashboard|cart|checkout|settings|auth-callback|payment-success|payment-cancelled|welcome)\\.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
